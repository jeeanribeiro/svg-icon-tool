{
  "name": "svg-icon-tool",
  "version": "3.0.1",
  "description": "CLI and library to square, center, and resize SVG icons — with proportional stroke scaling",
  "keywords": [
    "svg",
    "cli",
    "icons",
    "icon",
    "normalize",
    "resize",
    "stroke",
    "viewbox",
    "design-systems",
    "svgo"
  ],
  "homepage": "https://github.com/jeeanribeiro/svg-icon-tool#readme",
  "bugs": "https://github.com/jeeanribeiro/svg-icon-tool/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jeeanribeiro/svg-icon-tool.git"
  },
  "license": "MIT",
  "author": "Jean Ribeiro <contact@jeanribeiro.dev>",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "svg-icon-tool": "./dist/cli.js"
  },
  "files": [
    "dist",
    "CHANGELOG.md"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit && tsc -p playground --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "assets": "node scripts/build-assets.mjs",
    "prepublishOnly": "pnpm build",
    "playground:dev": "vite --config vite.playground.config.ts",
    "playground:build": "vite build --config vite.playground.config.ts",
    "playground:preview": "vite preview --config vite.playground.config.ts"
  },
  "dependencies": {
    "commander": "15.0.0",
    "svgo": "4.0.2",
    "svgpath": "2.6.0",
    "svgson": "5.3.1",
    "tinyglobby": "0.2.17"
  },
  "devDependencies": {
    "@changesets/cli": "2.31.1",
    "@eslint/js": "10.0.1",
    "@resvg/resvg-js": "^2.6.2",
    "@tailwindcss/vite": "^4.3.3",
    "@types/node": "26.1.1",
    "eslint": "10.7.0",
    "eslint-config-prettier": "10.1.8",
    "prettier": "3.9.5",
    "tailwindcss": "^4.3.3",
    "tsup": "8.5.1",
    "typescript": "5.9.3",
    "typescript-eslint": "8.64.0",
    "vite": "8.1.5",
    "vitest": "4.1.10"
  },
  "packageManager": "pnpm@10.29.3",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "engines": {
    "node": ">=24"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
